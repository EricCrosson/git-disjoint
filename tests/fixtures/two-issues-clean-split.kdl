title "two issues split cleanly into two branches"

base {
  file "src/lib.rs" "fn main() {}"
}

commit "feat: add widget\n\nTicket: AB-100" {
  file "src/widget.rs" "pub struct Widget;"
}
commit "feat: add gadget\n\nTicket: AB-200" {
  file "src/gadget.rs" "pub struct Gadget;"
}
commit "feat: extend widget\n\nTicket: AB-100" {
  file "src/widget.rs" "pub struct Widget;\nimpl Widget {}"
}

run "git-disjoint"
