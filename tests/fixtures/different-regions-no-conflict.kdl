title "same file different regions does not conflict"

base {
  file "src/lib.rs" "line 1\nline 2\nline 3\nline 4\nline 5\nline 6\nline 7\nline 8\nline 9\nline 10\n"
}

commit "feat: change top for widget\n\nTicket: AB-100" {
  file "src/lib.rs" "widget top\nline 2\nline 3\nline 4\nline 5\nline 6\nline 7\nline 8\nline 9\nline 10\n"
}
commit "feat: change bottom for gadget\n\nTicket: AB-200" {
  file "src/lib.rs" "line 1\nline 2\nline 3\nline 4\nline 5\nline 6\nline 7\nline 8\nline 9\ngadget bottom\n"
}

run "git-disjoint"
